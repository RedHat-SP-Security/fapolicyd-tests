component:
  - fapolicyd
require:
  - name: /Library/common
    url: https://github.com/RedHat-SP-Security/fapolicyd-tests
    ref: pk_deadlock
    type: library
  - fapolicyd
recommend:
  - fapolicyd-selinux
adjust:
  - enabled: false
    when: distro < rhel-8.1
    continue: false
framework: beakerlib
